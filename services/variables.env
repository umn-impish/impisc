HEALTH_MONITOR_PORT=12000
LOCAL_HEALTH_FWD_PORT=12001
HEALTH_CADENCE=10

# The gondola or wherever else we
# end up forwarding packets to,
# outside of IMPISH
ENDPOINT_IP="10.42.0.1"
ENDPOINT_PORT=12002

# Every packet gets sent through this program,
# and we increment a sequence number for every packet.
TELEMETER_PORT=13000
# Some filtering is applied to commands that hit this port.
# They're assumed to be ASCII strings,
# max size = the MTU of the gondola network
COMMAND_ROUTER_PORT=13001
# The command executor executes any canned/arbitrary commands
# and captures the stdout/stderr.
COMMAND_EXECUTOR_PORT=13002

# Used by journal_send script
LOCAL_JOURNAL_FWD_PORT=12003
JOURNAL_ARCHIVE_DIR="/data/journal/impish_journal"

# The endpoint for most packets:
# where data goes
ENDPOINT_IP="10.42.0.1"
ENDPOINT_PORT=12101

# Every packet gets sent through this program,
# and we increment a sequence number for every packet.
HEADER_STAMPER_PORT=13000
# Some filtering is applied to commands that hit this port.
# They're assumed to be ASCII strings,
# max size = the MTU of the gondola network
COMMAND_ROUTER_PORT=13001
# Define unlock timeout in seconds
COMMAND_UNLOCK_TIMEOUT=15
# The command executor executes any canned/arbitrary commands
# and captures the stdout/stderr.
COMMAND_EXECUTOR_PORT=13002

HEALTH_MONITOR_PORT=12000
LOCAL_HEALTH_FWD_PORT=12001
HEALTH_CADENCE=10
HEALTH_ENDPOINT="127.0.0.1:$HEADER_STAMPER_PORT"

TEMPERATURE_MONITOR_PORT=12100
TEMPERATURE_UDPCAP_PORT=12101
TEMPERATURE_CADENCE=5

HEATER_TRIGGER_TEMPERATURE=30
HEATER_HYSTERESIS=5
HEATER_CONTROLLER_PORT=12102

# Raw science data is passed to quicklook
# and rebinner for on-the-fly rebinning
RAW_SCIENCE_RECV_PORT=64000
SCIENCE_REBINNER_PORT=64400
SCIENCE_UDPCAP_PORT=64401

DEBUG_SPECTRUM_PORT=10000
DEBUG_WAVEFORM_PORT=10001

# Configurations for quicklook data
QUICKLOOK_UDPCAP_PORT=64002
QUICKLOOK_ENDPOINT="127.0.0.1:$HEADER_STAMPER_PORT"
QUICKLOOK_RECV_PORT=64321
QUICKLOOK_EDGES="0-100-300-500-1000"
# Enough frames for 4s of data
QUICKLOOK_FRAMES=$((32 * 4))

SCIENCE_BIAS_VOLTAGE=38
SCIENCE_REBIN_BINS=""

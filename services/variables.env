HEALTH_MONITOR_PORT=12000
LOCAL_HEALTH_FWD_PORT=12001
HEALTH_CADENCE=3

# The gondola or wherever else we
# end up forwarding packets to,
# outside of IMPISH
ENDPOINT_IP="10.42.0.1"
ENDPOINT_PORT="12002"

# Used by journal_send script
export LOCAL_JOURNAL_FWD_PORT=12003
export JOURNAL_ARCHIVE_DIR="/data/journal/impish_journal"

RAW_SCIENCE_RECV_PORT=64000

# Configurations for quicklook data
QUICKLOOK_UDPCAP_PORT=64002
QUICKLOOK_ENDPOINT="$ENDPOINT_IP:12003"
QUICKLOOK_RECV_PORT=64321
QUICKLOOK_EDGES="0-250-500-750-1000"
QUICKLOOK_SUM_SECONDS=4

#!/python-venv/bin/python
"""
Listens for all packets from IMPISH and sorts them, sending
them to their respective process for handling.
"""

import os
import socket

from ctypes import sizeof
from impisc import logging
from impisc.packets import HealthPacket, QuicklookPacket, CommandResponsePacket, PacketHeader

# TODO: update this to use definitions within impisc once settled:
HEADER_SIZE = sizeof(PacketHeader)
PACKET_MAP = {
    HEADER_SIZE + sizeof(HealthPacket): int(os.environ["LOCAL_HEALTH_FWD_PORT"]),
    HEADER_SIZE + sizeof(QuicklookPacket): int(os.environ["LOCAL_QUICKLOOK_FWD_PORT"]),
    HEADER_SIZE + sizeof(CommandResponsePacket): int(os.environ["LOCAL_COMMAND_FWD_PORT"]),
}
SORT_PORT = int(os.environ["SORT_PORT"])


def main():
    # Program can only end if killed, and sockets will be released by OS
    # Don't bother closing them
    with socket.socket(socket.AF_INET, socket.SOCK_DGRAM) as sock:
        sock.bind(("", SORT_PORT))
        logging.log_debug(f"Binding to port {SORT_PORT}")
        while True:
            data, addr = sock.recvfrom(8192)
            logging.log_debug(f"Received {len(data)} bytes from {addr[0]}:{addr[1]}")
            if len(data) in PACKET_MAP:
                port = PACKET_MAP[len(data)]
                len_sent: int = sock.sendto(data, ("", port))
                logging.log_debug(
                    f"Sent {len_sent} out of {len(data)} bytes to local port {port}"
                )
            else:
                logging.log_warning(f"Unknown packet ({len(data)} bytes) received on port {SORT_PORT} from {addr[0]}:{addr[1]}; discarding;\n{data}")


if __name__ == "__main__":
    main()

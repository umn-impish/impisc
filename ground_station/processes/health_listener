#!/python-venv/bin/python
"""
Listens for health packets from the IMPISH flight computer.
The received packets are put into a MySQL database to be read
and displayed by Grafana.
"""

import os
import time

from typing import Never

from mysql.connector.abstracts import MySQLConnectionAbstract
from mysql.connector.errors import IntegrityError
from mysql.connector.pooling import PooledMySQLConnection

from impisc import logging, packets

import impish_monitor as monitor


LISTEN_PORT = int(os.environ["LOCAL_HEALTH_FWD_PORT"])


def unpack_power_byte(byte: int) -> dict[str, int]:
    """Map the power status bits."""
    power_cols: list[str] = [
        c for c in monitor.HEALTH_COLUMNS.keys() if c.startswith("power_")
    ]
    power_cols.remove("power_line_statuses")
    bools: dict[str, int] = {
        c: int((byte >> i) & 1) for i, c in enumerate(reversed(power_cols))
    }
    return bools


def unpack_missing_bytes(mbytes: int) -> dict[str, int]:
    """Map the missing status bits."""
    missing_cols: list[str] = [
        c for c in monitor.HEALTH_COLUMNS.keys() if c.startswith("missing_")
    ]
    missing_cols.remove("missing_fields")
    bools: dict[str, int] = {
        c: int((mbytes >> i) & 1) for i, c in enumerate(missing_cols)
    }
    return bools


def insert_packet(
    db: PooledMySQLConnection | MySQLConnectionAbstract, packet: packets.HealthPacket
):
    """Insert the health packet into the database."""
    cols = {
        "unix_timestamp": packet.timestamp,
        "gs_unix_timestamp": int(time.time()),
        **{f[0]: getattr(packet, f[0]) for f in packet._fields_ if "extra" not in f},
    }
    cols.pop("timestamp")  # remove `timestamp` field...
    cols = {**cols, **unpack_power_byte(getattr(packet, "power_line_statuses"))}
    cols = {**cols, **unpack_missing_bytes(getattr(packet, "missing_fields"))}
    fmt = "%s, " * (len(cols) - 1) + "%s"

    # Save the keys to ensure they remain ordered the same as the values
    keys = list(cols.keys())
    header = f"INSERT INTO {monitor.HEALTH_TABLE_NAME}"
    sql = f"{header} ({', '.join(keys)}) VALUES ({fmt})"
    val = tuple(cols[k] for k in keys)
    logging.log_info(f"Executing: {header}")
    logging.log_debug(f"{sql}\n{val}")
    cursor = db.cursor()
    try:
        _ = cursor.execute(sql, val)
    except IntegrityError as e:
        # Ignore duplicate key
        logging.log_warning(f"Ignoring integrity error: {e}")
        return
    _ = db.commit()


def main() -> Never:
    monitor.listener(
        port=LISTEN_PORT,
        PacketClass=packets.HealthPacket,
        insert_func=insert_packet
    )


if __name__ == "__main__":
    main()

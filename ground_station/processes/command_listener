#!/python-venv/bin/python
"""
Listens for command response packets from the IMPISH flight computer.
Currently, the data is inserted in to a MySQL table.
"""

import os
import socket
import time

from mysql.connector.pooling import PooledMySQLConnection
from mysql.connector.abstracts import MySQLConnectionAbstract

import impish_monitor as monitor

from impisc import logging, packets


LISTEN_PORT = int(os.environ["LOCAL_COMMAND_FWD_PORT"])


def insert_packet(
    db: PooledMySQLConnection | MySQLConnectionAbstract,
    packet: packets.CommandResponsePacket
):
    """Insert the health packet into the database."""
    logging.log_debug(str(packet.timestamp))
    cols: dict[str, int] = {"unix_timestamp": packet.timestamp}
    for i in range(1, packets.NUM_DET_CHANNELS + 1):
        quicklook_bins = packet.channels[i - 1]
        for bin, cts in enumerate(quicklook_bins, start=1):
            cols[f"chan{i}_ebin{bin}"] = cts
    fmt = "%s, " * (len(cols) - 1) + "%s"
    header = f"INSERT INTO {monitor.COMMAND_TABLE_NAME}"

    # Save the keys to ensure they remain ordered the same as the values
    keys = list(cols.keys())
    sql = f"{header} ({', '.join(keys)}) VALUES ({fmt})"
    vals = tuple(cols[k] for k in keys)
    logging.log_info(f"Executing: {header}")
    logging.log_debug(f"sql: {sql}")
    logging.log_debug(f"val: {vals}")
    cursor = db.cursor()
    _ = cursor.execute(sql, vals)
    _ = db.commit()


def main():
    """Infinitely loop, listening for incoming packets then writing them
    to the database.
    """
    logging.log_debug("Opening DB connection")
    db = monitor.connect()
    expected_seqnum = 0
    sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    logging.log_debug(f"Binding to port {LISTEN_PORT}")
    sock.bind(("", LISTEN_PORT))
    try:
        while True:
            data, addr = sock.recvfrom(8192)
            logging.log_debug(f"{len(data)} bytes received from {addr[0]}:{addr[1]}")
            logging.log_debug(f"{data}")
            if monitor.validate_packet(data, packets.CommandResponsePacket):
                header, packet = packets.split(data)
                expected_seqnum = monitor.process_sequence_number(header, expected_seqnum)
                logging.log_debug(f"{header.id} {header.sequence_number} {header.packet_size}\n{packet.timestamp} {packet.response}")
                # insert_packet(db, packet=packet)
    finally:
        logging.log_debug("Closing DB connection")
        sock.close()
        db.close()


if __name__ == "__main__":
    main()
